@page "{id:int}"
@model StudentApp.Web.Pages.Students.DetailsModel
@{
    ViewData["Title"] = "Student Details";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Student Details</h2>
            <a asp-page="Index" class="btn btn-outline-secondary btn-sm">← Back to list</a>
        </div>

        @if (Model.Student is null)
        {
            <div class="alert alert-warning">Student not found.</div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <dl class="row">
                        <dt class="col-sm-4">Full Name</dt>
                        <dd class="col-sm-8">@Model.Student.FirstName @Model.Student.LastName</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Student.Email</dd>

                        <dt class="col-sm-4">Date of Birth</dt>
                        <dd class="col-sm-8">@Model.Student.DateOfBirth.ToString("dd MMMM yyyy")</dd>

                        <dt class="col-sm-4">Grade</dt>
                        <dd class="col-sm-8"><span class="badge bg-primary fs-6">@Model.Student.Grade</span></dd>

                        <dt class="col-sm-4">Registered On</dt>
                        <dd class="col-sm-8">@Model.Student.CreatedAt.ToString("dd MMM yyyy HH:mm") UTC</dd>
                    </dl>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-page="Edit" asp-route-id="@Model.Student.Id" class="btn btn-primary btn-sm">Edit</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Student.Id"
                          onsubmit="return confirm('Delete this student?')">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
