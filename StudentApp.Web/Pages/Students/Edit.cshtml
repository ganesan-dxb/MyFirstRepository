@page "{id:int}"
@model StudentApp.Web.Pages.Students.EditModel
@{
    ViewData["Title"] = "Edit Student";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Edit Student</h2>

        @if (Model.StudentNotFound)
        {
            <div class="alert alert-warning">Student not found. <a asp-page="Index">Back to list</a></div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="StudentId" />

                        <div class="mb-3">
                            <label asp-for="Input.FirstName" class="form-label fw-semibold">First Name</label>
                            <input asp-for="Input.FirstName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.LastName" class="form-label fw-semibold">Last Name</label>
                            <input asp-for="Input.LastName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Input.Email" type="email" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                            <input asp-for="Input.DateOfBirth" type="date" class="form-control" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.Grade" class="form-label fw-semibold">Grade</label>
                            <select asp-for="Input.Grade" class="form-select" required>
                                <option>A+</option>
                                <option>A</option>
                                <option>B+</option>
                                <option>B</option>
                                <option>C</option>
                                <option>D</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Update Student</button>
                            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
