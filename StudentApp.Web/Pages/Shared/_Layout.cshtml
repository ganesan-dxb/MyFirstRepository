<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — StudentApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar { background-color: #1a3a5c !important; }
        .cache-badge { font-size: 0.75rem; }
        .table th { background-color: #1a3a5c; color: white; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🎓 StudentApp</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="/Students">Students</a>
                <a class="nav-link text-white" href="/Students/Create">Add Student</a>
            </div>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="text-center text-muted py-4 mt-5">
        <small>StudentApp · ASP.NET Core 10 · YARP · Redis · MS SQL Server</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
